generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id              Int        @id @default(autoincrement())
  nome            String?
  telefone        String     @unique
  status          String     @default("ativo")
  observacoes     String?
  dataCadastro    DateTime   @default(now())
  dataAtualizacao DateTime   @updatedAt
  conversas       Conversa[]

  @@map("clientes")
}

model Conversa {
  id              Int        @id @default(autoincrement())
  clienteId       Int?
  telefone        String
  status          String     @default("aberta")
  etapaAtual      String?
  dataAbertura    DateTime   @default(now())
  dataAtualizacao DateTime   @updatedAt
  cliente         Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  mensagens       Mensagem[]

  @@index([telefone])
  @@index([clienteId])
  @@map("conversas")
}

model Mensagem {
  id         Int       @id @default(autoincrement())
  conversaId Int?
  telefone   String
  direcao    String
  conteudo   String
  origem     String    @default("whatsapp")
  dataHora   DateTime  @default(now())
  conversa   Conversa? @relation(fields: [conversaId], references: [id], onDelete: SetNull)

  @@index([telefone])
  @@index([conversaId])
  @@map("mensagens")
}

model MenuOpcao {
  id                 Int      @id @default(autoincrement())
  codigo             String
  descricao          String
  respostaAutomatica String
  ativo              Boolean  @default(true)
  dataCriacao        DateTime @default(now())
  dataAtualizacao    DateTime @updatedAt

  @@index([codigo])
  @@map("menu_opcoes")
}

model MenuConfiguracao {
  id              Int      @id @default(autoincrement())
  chave           String   @unique
  valor           String
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  @@map("menu_configuracoes")
}

model LogIntegracao {
  id              Int      @id @default(autoincrement())
  tipo            String
  origem          String?
  destino         String?
  status          String   @default("registrado")
  mensagem        String?
  payloadRecebido Json?
  payloadEnviado  Json?
  dataHora        DateTime @default(now())

  @@index([tipo])
  @@index([dataHora])
  @@map("logs_integracao")
}

model ContatoEnvio {
  id         Int      @id @default(autoincrement())
  nome       String
  telefone   String   @unique
  ativo      Boolean  @default(true)
  observacao String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contatos_envio")
}
