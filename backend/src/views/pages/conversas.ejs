<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Conversas</h1>
    <p class="text-secondary mb-0">Atendimentos vinculados aos telefones recebidos.</p>
  </div>
  <span class="badge text-bg-secondary align-self-start align-self-md-center"><%= conversas.length %> registro(s)</span>
</div>

<div class="card">
  <div class="card-body">
    <% if (conversas.length === 0) { %>
      <p class="text-secondary mb-0">Nenhuma conversa registrada ainda.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Cliente</th>
              <th>Telefone</th>
              <th>Status</th>
              <th>Etapa</th>
              <th>Abertura</th>
              <th>Atualizacao</th>
            </tr>
          </thead>
          <tbody>
            <% conversas.forEach((conversa) => { %>
              <tr>
                <td><%= conversa.id %></td>
                <td><%= conversa.cliente ? (conversa.cliente.nome || conversa.cliente.telefone) : '-' %></td>
                <td><%= conversa.telefone %></td>
                <td><span class="badge text-bg-<%= conversa.status === 'aberta' ? 'success' : 'secondary' %>"><%= conversa.status %></span></td>
                <td><%= conversa.etapaAtual || '-' %></td>
                <td><%= conversa.dataAbertura.toLocaleString('pt-BR') %></td>
                <td><%= conversa.dataAtualizacao.toLocaleString('pt-BR') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
