<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Logs</h1>
    <p class="text-secondary mb-0">Eventos importantes registrados pelas integracoes.</p>
  </div>
  <span class="badge text-bg-secondary align-self-start align-self-md-center"><%= logs.length %> registro(s)</span>
</div>

<div class="card">
  <div class="card-body">
    <% if (logs.length === 0) { %>
      <p class="text-secondary mb-0">Nenhum log registrado ainda.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Tipo</th>
              <th>Origem</th>
              <th>Destino</th>
              <th>Status</th>
              <th>Mensagem</th>
              <th>Data</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach((log) => { %>
              <tr>
                <td><%= log.id %></td>
                <td><%= log.tipo %></td>
                <td><%= log.origem || '-' %></td>
                <td><%= log.destino || '-' %></td>
                <td><span class="badge text-bg-secondary"><%= log.status %></span></td>
                <td class="text-truncate table-text"><%= log.mensagem || '-' %></td>
                <td><%= log.dataHora.toLocaleString('pt-BR') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
