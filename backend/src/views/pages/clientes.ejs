<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Clientes</h1>
    <p class="text-secondary mb-0">Contatos registrados a partir da API e do webhook.</p>
  </div>
  <span class="badge text-bg-secondary align-self-start align-self-md-center"><%= clientes.length %> registro(s)</span>
</div>

<div class="card">
  <div class="card-body">
    <% if (clientes.length === 0) { %>
      <p class="text-secondary mb-0">Nenhum cliente cadastrado ainda.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nome</th>
              <th>Telefone</th>
              <th>Status</th>
              <th>Cadastro</th>
              <th>Observacoes</th>
            </tr>
          </thead>
          <tbody>
            <% clientes.forEach((cliente) => { %>
              <tr>
                <td><%= cliente.id %></td>
                <td><%= cliente.nome || '-' %></td>
                <td><%= cliente.telefone %></td>
                <td><span class="badge text-bg-success"><%= cliente.status %></span></td>
                <td><%= cliente.dataCadastro.toLocaleString('pt-BR') %></td>
                <td class="text-truncate table-text"><%= cliente.observacoes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
