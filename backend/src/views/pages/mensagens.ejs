<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Mensagens</h1>
    <p class="text-secondary mb-0">Historico de mensagens recebidas e enviadas.</p>
  </div>
  <span class="badge text-bg-secondary align-self-start align-self-md-center"><%= mensagens.length %> registro(s)</span>
</div>

<div class="card">
  <div class="card-body">
    <% if (mensagens.length === 0) { %>
      <p class="text-secondary mb-0">Nenhuma mensagem registrada ainda.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Conversa</th>
              <th>Telefone</th>
              <th>Direcao</th>
              <th>Origem</th>
              <th>Conteudo</th>
              <th>Data</th>
            </tr>
          </thead>
          <tbody>
            <% mensagens.forEach((mensagem) => { %>
              <tr>
                <td><%= mensagem.id %></td>
                <td><%= mensagem.conversaId || '-' %></td>
                <td><%= mensagem.telefone %></td>
                <td><span class="badge text-bg-<%= mensagem.direcao === 'enviada' ? 'primary' : 'success' %>"><%= mensagem.direcao %></span></td>
                <td><%= mensagem.origem %></td>
                <td class="text-truncate table-text"><%= mensagem.conteudo %></td>
                <td><%= mensagem.dataHora.toLocaleString('pt-BR') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
