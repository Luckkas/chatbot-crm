<%- include('../../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Criar disparo</h1>
    <p class="text-secondary mb-0">Selecione contatos ativos e prepare a mensagem para o n8n enviar.</p>
  </div>
  <a class="btn btn-outline-secondary align-self-start align-self-md-center" href="/disparos">Voltar</a>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<form method="post" action="/disparos">
  <div class="row g-3">
    <div class="col-12 col-lg-5">
      <div class="card h-100">
        <div class="card-header bg-white">
          <strong>Contatos ativos</strong>
        </div>
        <div class="card-body">
          <% if (contatos.length === 0) { %>
            <p class="text-secondary mb-0">Nenhum contato ativo disponivel para disparo.</p>
          <% } else { %>
            <div class="list-group">
              <% contatos.forEach((contato) => { %>
                <label class="list-group-item d-flex gap-3 align-items-start">
                  <input class="form-check-input mt-1" type="checkbox" name="contatoIds" value="<%= contato.id %>" <%= disparo.contatoIds.includes(contato.id) ? 'checked' : '' %>>
                  <span>
                    <strong class="d-block"><%= contato.nome %></strong>
                    <span class="text-secondary"><%= contato.telefone %></span>
                  </span>
                </label>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="card h-100">
        <div class="card-header bg-white">
          <strong>Mensagem do menu</strong>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label" for="titulo">Titulo do disparo</label>
            <input class="form-control" id="titulo" name="titulo" value="<%= disparo.titulo || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="mensagem">Previa editavel</label>
            <textarea class="form-control" id="mensagem" name="mensagem" rows="10" required><%= disparo.mensagem || '' %></textarea>
          </div>
          <div class="d-flex justify-content-end gap-2">
            <a class="btn btn-outline-secondary" href="/disparos">Cancelar</a>
            <button class="btn btn-primary" type="submit" <%= contatos.length === 0 ? 'disabled' : '' %>>Criar disparo</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</form>

<%- include('../../partials/footer') %>
