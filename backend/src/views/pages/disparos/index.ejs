<%- include('../../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Disparos</h1>
    <p class="text-secondary mb-0">Menus preparados para o n8n enviar pelo WhatsApp.</p>
  </div>
  <a class="btn btn-primary align-self-start align-self-md-center" href="/disparos/novo">Criar disparo</a>
</div>

<% if (mensagem.sucesso) { %>
  <div class="alert alert-success"><%= mensagem.sucesso %></div>
<% } %>

<% if (mensagem.erro) { %>
  <div class="alert alert-danger"><%= mensagem.erro %></div>
<% } %>

<div class="card">
  <div class="card-body">
    <% if (disparos.length === 0) { %>
      <p class="text-secondary mb-0">Nenhum disparo criado ainda.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Titulo</th>
              <th>Status</th>
              <th>Contatos</th>
              <th>Envios</th>
              <th>Criado em</th>
              <th>Mensagem</th>
              <th class="text-end">Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% disparos.forEach((disparo) => { %>
              <tr>
                <td><%= disparo.id %></td>
                <td><%= disparo.titulo %></td>
                <td><span class="badge text-bg-<%= disparo.status === 'pendente' ? 'warning' : (disparo.status === 'enviado' ? 'success' : 'secondary') %>"><%= disparo.status %></span></td>
                <td><%= disparo.contatos.length %></td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <% const enviados = disparo.contatos.filter((item) => item.statusEnvio === 'enviado').length; %>
                    <% const pendentes = disparo.contatos.filter((item) => item.statusEnvio === 'pendente').length; %>
                    <% const erros = disparo.contatos.filter((item) => item.statusEnvio === 'erro').length; %>
                    <span class="badge text-bg-success"><%= enviados %> enviados</span>
                    <span class="badge text-bg-warning"><%= pendentes %> pendentes</span>
                    <span class="badge text-bg-danger"><%= erros %> erros</span>
                  </div>
                </td>
                <td><%= disparo.createdAt.toLocaleString('pt-BR') %></td>
                <td class="text-truncate table-text"><%= disparo.mensagem %></td>
                <td>
                  <div class="d-flex justify-content-end">
                    <form method="post" action="/disparos/<%= disparo.id %>/excluir" onsubmit="return confirm('Excluir este disparo?');">
                      <button class="btn btn-sm btn-outline-danger" type="submit">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../../partials/footer') %>
