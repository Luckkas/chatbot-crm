<%- include('../../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1"><%= formTitle %></h1>
    <p class="text-secondary mb-0">Informe os dados do contato usado nos disparos via n8n.</p>
  </div>
  <a class="btn btn-outline-secondary align-self-start align-self-md-center" href="/contatos-envio">Voltar</a>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <label class="form-label" for="nome">Nome</label>
          <input class="form-control" id="nome" name="nome" value="<%= contato.nome || '' %>" required>
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="telefone">Telefone</label>
          <input class="form-control" id="telefone" name="telefone" value="<%= contato.telefone || '' %>" required>
        </div>
        <div class="col-12">
          <label class="form-label" for="observacao">Observacao</label>
          <textarea class="form-control" id="observacao" name="observacao" rows="3"><%= contato.observacao || '' %></textarea>
        </div>
        <div class="col-12">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="ativo" name="ativo" <%= contato.ativo ? 'checked' : '' %>>
            <label class="form-check-label" for="ativo">Contato ativo</label>
          </div>
        </div>
      </div>
      <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-secondary" href="/contatos-envio">Cancelar</a>
        <button class="btn btn-primary" type="submit">Salvar</button>
      </div>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>
