<%- include('../../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1">Contatos de envio</h1>
    <p class="text-secondary mb-0">Pessoas que podem receber mensagens automaticas disparadas pelo n8n.</p>
  </div>
  <a class="btn btn-primary align-self-start align-self-md-center" href="/contatos-envio/novo">Novo contato</a>
</div>

<% if (mensagem.sucesso) { %>
  <div class="alert alert-success"><%= mensagem.sucesso %></div>
<% } %>

<% if (mensagem.erro) { %>
  <div class="alert alert-danger"><%= mensagem.erro %></div>
<% } %>

<div class="card">
  <div class="card-body">
    <% if (contatos.length === 0) { %>
      <p class="text-secondary mb-0">Nenhum contato de envio cadastrado ainda.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nome</th>
              <th>Telefone</th>
              <th>Status</th>
              <th>Observacao</th>
              <th>Atualizacao</th>
              <th class="text-end">Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% contatos.forEach((contato) => { %>
              <tr>
                <td><%= contato.id %></td>
                <td><%= contato.nome %></td>
                <td><%= contato.telefone %></td>
                <td><span class="badge text-bg-<%= contato.ativo ? 'success' : 'secondary' %>"><%= contato.ativo ? 'ativo' : 'inativo' %></span></td>
                <td class="text-truncate table-text"><%= contato.observacao || '-' %></td>
                <td><%= contato.updatedAt.toLocaleString('pt-BR') %></td>
                <td>
                  <div class="d-flex justify-content-end gap-2 flex-wrap">
                    <a class="btn btn-sm btn-outline-primary" href="/contatos-envio/<%= contato.id %>/editar">Editar</a>
                    <form method="post" action="/contatos-envio/<%= contato.id %>/toggle">
                      <button class="btn btn-sm btn-outline-secondary" type="submit"><%= contato.ativo ? 'Desativar' : 'Ativar' %></button>
                    </form>
                    <form method="post" action="/contatos-envio/<%= contato.id %>/excluir" onsubmit="return confirm('Excluir este contato?');">
                      <button class="btn btn-sm btn-outline-danger" type="submit">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../../partials/footer') %>
