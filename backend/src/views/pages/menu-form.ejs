<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
  <div>
    <h1 class="h3 mb-1"><%= formTitle %></h1>
    <p class="text-secondary mb-0">Configure codigo, descricao e resposta enviada ao usuario.</p>
  </div>
  <a class="btn btn-outline-secondary align-self-start align-self-md-center" href="/menu">Voltar</a>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <label class="form-label" for="codigo">Codigo</label>
          <input class="form-control" id="codigo" name="codigo" value="<%= opcao.codigo || '' %>" required>
        </div>
        <div class="col-12 col-md-8">
          <label class="form-label" for="descricao">Descricao</label>
          <input class="form-control" id="descricao" name="descricao" value="<%= opcao.descricao || '' %>" required>
        </div>
        <div class="col-12">
          <label class="form-label" for="respostaAutomatica">Resposta automatica</label>
          <textarea class="form-control" id="respostaAutomatica" name="respostaAutomatica" rows="5" required><%= opcao.respostaAutomatica || '' %></textarea>
        </div>
        <div class="col-12">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="ativo" name="ativo" <%= opcao.ativo ? 'checked' : '' %>>
            <label class="form-check-label" for="ativo">Opcao ativa</label>
          </div>
        </div>
      </div>
      <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-secondary" href="/menu">Cancelar</a>
        <button class="btn btn-primary" type="submit">Salvar</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
